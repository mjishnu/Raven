<Page
    x:Class="Raven.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Raven.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>
    <Grid>
        <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="0"
                Margin="0,24,0,16"
                Spacing="4">
                <TextBlock x:Uid="Settings_Title" Style="{ThemeResource TitleTextBlockStyle}" />
            </StackPanel>
            <ScrollViewer
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
                <StackPanel Padding="0,0,0,24" Spacing="16">
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_Theme"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <StackPanel Grid.Row="1" Spacing="8">
                            <RadioButton
                                x:Uid="Settings_Theme_Light"
                                Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                GroupName="AppTheme"
                                IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}">
                                <RadioButton.CommandParameter>
                                    <xaml:ElementTheme>Light</xaml:ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton
                                x:Uid="Settings_Theme_Dark"
                                Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                GroupName="AppTheme"
                                IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}">
                                <RadioButton.CommandParameter>
                                    <xaml:ElementTheme>Dark</xaml:ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton
                                x:Uid="Settings_Theme_Default"
                                Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                GroupName="AppTheme"
                                IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default, Mode=OneWay}">
                                <RadioButton.CommandParameter>
                                    <xaml:ElementTheme>Default</xaml:ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_LocaleAndRegion"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Uid="Settings_Language" Grid.Row="1" />
                        <ComboBox
                            Grid.Row="2"
                            MinWidth="260"
                            MaxWidth="340"
                            HorizontalAlignment="Left"
                            ItemsSource="{x:Bind ViewModel.AllLanguageNames}"
                            SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}" />
                        <TextBlock
                            x:Uid="Settings_Market"
                            Grid.Row="3"
                            Margin="0,4,0,0" />
                        <ComboBox
                            Grid.Row="4"
                            MinWidth="260"
                            MaxWidth="340"
                            HorizontalAlignment="Left"
                            ItemsSource="{x:Bind ViewModel.AllMarketNames}"
                            SelectedIndex="{x:Bind ViewModel.SelectedMarketIndex, Mode=TwoWay}" />
                    </Grid>
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_Architecture"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            x:Uid="Settings_ArchitectureDescription"
                            Grid.Row="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            TextWrapping="Wrap" />
                        <ComboBox
                            Grid.Row="2"
                            MinWidth="260"
                            MaxWidth="340"
                            HorizontalAlignment="Left"
                            ItemsSource="{x:Bind ViewModel.AllArchitectureNames}"
                            SelectedIndex="{x:Bind ViewModel.SelectedArchitectureIndex, Mode=TwoWay}" />
                    </Grid>
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_Reset"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            x:Uid="Settings_ResetDescription"
                            Grid.Row="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}" />
                        <Button
                            x:Uid="Settings_ResetButton"
                            Grid.Row="2"
                            Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Click="ResetButton_Click" />
                    </Grid>
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_DiagnosticsLogs"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            x:Uid="Settings_DiagnosticsLogsDescription"
                            Grid.Row="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            TextWrapping="Wrap" />
                        <Button
                            x:Uid="Settings_DiagnosticsLogsButton"
                            Grid.Row="2"
                            Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Click="OpenLogsFolderButton_Click" />
                    </Grid>
                    <Grid
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="Settings_About"
                            Grid.Row="0"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            Grid.Row="1"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" />
                        <TextBlock
                            x:Uid="Settings_AboutDescription"
                            Grid.Row="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            TextWrapping="Wrap" />
                        <StackPanel
                            Grid.Row="3"
                            Margin="-12,4,0,0"
                            Spacing="0">
                            <HyperlinkButton x:Uid="SettingsPage_GitHubRepoLink" NavigateUri="https://github.com/mjishnu/Raven" />
                            <HyperlinkButton x:Uid="SettingsPage_LicenseLink" Click="LicenseLink_Click" />
                            <HyperlinkButton x:Uid="SettingsPage_ThirdPartyLicensesLink" Click="ThirdPartyLicensesLink_Click" />
                        </StackPanel>
                        <Button
                            x:Uid="Settings_AppUpdatesButton"
                            Grid.Row="4"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Click="CheckForAppUpdatesButton_Click" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <Grid
            x:Name="LicenseLightbox"
            Grid.RowSpan="2"
            Background="#80000000"
            Canvas.ZIndex="10"
            Tapped="LicenseLightboxBackdrop_Tapped"
            Visibility="Collapsed">
            <Border
                MaxWidth="720"
                MaxHeight="680"
                Margin="24"
                Padding="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Tapped="LicenseLightboxContent_Tapped">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="Settings_LicenseDialogTitle"
                        Grid.Row="0"
                        Margin="4,0,4,0"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,4,0,0"
                        Padding="4"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            x:Name="LicenseTextBlock"
                            Margin="4"
                            FontFamily="Consolas"
                            IsTextSelectionEnabled="False"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                    <Button
                        x:Uid="Settings_LicenseDialogClose"
                        Grid.Row="2"
                        MinWidth="100"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        Click="LicenseLightboxCloseButton_Click" />
                </Grid>
            </Border>
        </Grid>
        <Grid
            x:Name="ThirdPartyLicensesLightbox"
            Grid.RowSpan="2"
            Background="#80000000"
            Canvas.ZIndex="10"
            Tapped="ThirdPartyLicensesLightboxBackdrop_Tapped"
            Visibility="Collapsed">
            <Border
                MaxWidth="720"
                MaxHeight="680"
                Margin="24"
                Padding="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Tapped="ThirdPartyLicensesLightboxContent_Tapped">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="Settings_ThirdPartyLicensesDialogTitle"
                        Grid.Row="0"
                        Margin="4,0,4,0"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,4,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <Expander
                            Margin="0,0,0,2"
                            HorizontalAlignment="Stretch"
                            IsExpanded="True">
                            <Expander.Header>
                                <TextBlock x:Uid="Settings_ThirdPartyLicenseStoreListingsHeader" />
                            </Expander.Header>
                            <Border
                                Margin="0,8,0,0"
                                Padding="4"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <ScrollViewer
                                    MaxHeight="360"
                                    Padding="4"
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto">
                                    <TextBlock
                                        x:Name="ThirdPartyStoreListingsLicenseTextBlock"
                                        Margin="4"
                                        FontFamily="Consolas"
                                        IsTextSelectionEnabled="False"
                                        TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Expander>
                    </ScrollViewer>
                    <Button
                        x:Uid="Settings_LicenseDialogClose"
                        Grid.Row="2"
                        MinWidth="100"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right"
                        Click="ThirdPartyLicensesLightboxCloseButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
