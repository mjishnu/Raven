<Page
  x:Class="test.Views.UpdatesPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:helper="using:test.Helpers"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:models="using:test.Models"
  mc:Ignorable="d"
>
  <Page.Resources>
    <helper:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <helper:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <Style x:Key="TransparentButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8" />
    </Style>
    <Style
      x:Key="IconButtonStyle"
      BasedOn="{StaticResource TransparentButtonStyle}"
      TargetType="Button"
    >
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Page.Resources>
  <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <!--  Header  -->
    <Grid Grid.Row="0" Margin="0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Style="{ThemeResource TitleTextBlockStyle}" Text="Updates" />
      <!--  Normal action button (hidden while checking)  -->
      <Button
        x:Name="ActionButton"
        Grid.Column="1"
        Click="ActionButton_Click"
        Content="{x:Bind ViewModel.ButtonText, Mode=OneWay}"
        IsEnabled="{x:Bind ViewModel.ButtonEnabled, Mode=OneWay}"
        Style="{ThemeResource AccentButtonStyle}"
        Visibility="{x:Bind ViewModel.IsChecking, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
      />
      <!--  Stop button (visible only while checking)  -->
      <Button
        Grid.Column="1"
        Click="StopCheckButton_Click"
        Style="{ThemeResource AccentButtonStyle}"
        Visibility="{x:Bind ViewModel.IsChecking, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
      >
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon FontSize="12" Glyph="" />
          <TextBlock Text="Stop" />
        </StackPanel>
      </Button>
    </Grid>
    <!--  State A: Empty (no updates, not checking)  -->
    <StackPanel
      Grid.Row="1"
      Margin="0,0,0,70"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Spacing="8"
      Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <FontIcon
        HorizontalAlignment="Center"
        FontSize="48"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        Glyph=""
      />
      <TextBlock
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        Style="{ThemeResource SubtitleTextBlockStyle}"
        Text="No new updates"
        TextAlignment="Center"
      />
    </StackPanel>
    <!--  State B: Checking (progress ring)  -->
    <StackPanel
      Grid.Row="1"
      Margin="0,0,0,70"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Spacing="16"
      Visibility="{x:Bind ViewModel.IsChecking, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <ProgressRing Width="48" Height="48" Background="LightGray" IsActive="True" />
      <!--
                Base text and dots in separate blocks so only dots animate;
                the base never shifts. Dots use U+2008 (PUNCTUATION SPACE) as
                filler so the dots area is always exactly 3-period-widths wide.
            -->
      <StackPanel
        Margin="20,0,0,0"
        HorizontalAlignment="Center"
        Orientation="Horizontal"
        Spacing="0"
      >
        <TextBlock
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Style="{ThemeResource BodyTextBlockStyle}"
          Text="{x:Bind ViewModel.CheckingProgressBase, Mode=OneWay}"
        />
        <TextBlock
          Width="24"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          HorizontalTextAlignment="Left"
          Style="{ThemeResource BodyTextBlockStyle}"
          Text="{x:Bind ViewModel.CheckingProgressDots, Mode=OneWay}"
        />
      </StackPanel>
    </StackPanel>
    <!--  State C: Updates available and/or completed (scrollable list)  -->
    <ScrollViewer
      Grid.Row="1"
      Visibility="{x:Bind ViewModel.ShowUpdatesList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <StackPanel Padding="0,0,0,24" Spacing="8">
        <!--  Select All  -->
        <CheckBox
          x:Name="SelectAllCheckBox"
          Margin="0,0,0,4"
          Click="SelectAll_Click"
          Content="Select all"
          IsChecked="{x:Bind ViewModel.IsAllSelected, Mode=OneWay}"
          Visibility="{x:Bind ViewModel.HasUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
        />
        <!--  Available Updates  -->
        <ListView
          x:Name="UpdatesList"
          IsItemClickEnabled="True"
          ItemClick="UpdateItem_ItemClick"
          ItemsSource="{x:Bind ViewModel.AvailableUpdates, Mode=OneWay}"
          SelectionMode="None"
          Visibility="{x:Bind ViewModel.HasUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
        >
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,4" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:UpdateItem">
              <Grid
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                ColumnSpacing="12"
                CornerRadius="8"
              >
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="60" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Checkbox  -->
                <CheckBox
                  Grid.Column="0"
                  MinWidth="20"
                  VerticalAlignment="Center"
                  Click="ItemCheckBox_Click"
                  IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                  IsEnabled="{x:Bind IsCheckboxEnabled, Mode=OneWay}"
                />
                <!--  App icon  -->
                <Border
                  Grid.Column="1"
                  Width="60"
                  Height="60"
                  VerticalAlignment="Top"
                  CornerRadius="8"
                >
                  <Image Source="{Binding LogoUrl, Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
                <!--  Info column  -->
                <Grid Grid.Column="2" VerticalAlignment="Top" RowSpacing="6">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock
                    Grid.Row="0"
                    FontWeight="SemiBold"
                    Text="{x:Bind Title, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                  />
                  <!--  Row 1: version info OR progress  -->
                  <Grid Grid.Row="1">
                    <!--  Version text (visible when not active)  -->
                    <TextBlock
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                      Style="{ThemeResource CaptionTextBlockStyle}"
                      Visibility="{x:Bind IsVersionVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    >
                      <Run Text="{x:Bind InstalledVersion, Mode=OneWay}" />
                      <Run Text="→" />
                      <Run Text="{x:Bind StoreVersion, Mode=OneWay}" />
                    </TextBlock>
                    <!--  Progress area (visible when active)  -->
                    <StackPanel
                      Spacing="4"
                      Visibility="{x:Bind IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    >
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                          Grid.Column="0"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          Style="{ThemeResource CaptionTextBlockStyle}"
                          Text="{Binding StatusText, Mode=OneWay}"
                        />
                        <!--  Download details (percent + size) - Downloading only  -->
                        <TextBlock
                          Grid.Column="1"
                          HorizontalAlignment="Right"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Style="{ThemeResource CaptionTextBlockStyle}"
                          Text="{Binding DisplayDetailsText, Mode=OneWay}"
                          Visibility="{Binding Status, Converter={StaticResource DownloadDetailsStatusToVisibilityConverter}, Mode=OneWay}"
                        />
                        <!--  Installing: progress percent only  -->
                        <TextBlock
                          Grid.Column="1"
                          HorizontalAlignment="Right"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Style="{ThemeResource CaptionTextBlockStyle}"
                          Visibility="{Binding Status, Converter={StaticResource InstallingStatusToVisibilityConverter}, Mode=OneWay}"
                        >
                          <Run Text="{Binding Progress, Mode=OneWay, Converter={StaticResource ProgressToPercentTextConverter}}" />
                        </TextBlock>
                      </Grid>
                      <ProgressBar
                        IsIndeterminate="{Binding Status, Converter={StaticResource DownloadStatusToIndeterminateConverter}, Mode=OneWay}"
                        Maximum="100"
                        Value="{Binding Progress, Mode=OneWay}"
                      />
                    </StackPanel>
                  </Grid>
                </Grid>
                <!--  Cancel button (visible while update is in progress)  -->
                <Button
                  Grid.Column="3"
                  VerticalAlignment="Center"
                  Click="CancelUpdateButton_Click"
                  Style="{StaticResource IconButtonStyle}"
                  Tag="{x:Bind ProductId}"
                  ToolTipService.ToolTip="Cancel update"
                  Visibility="{x:Bind IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                >
                  <FontIcon FontSize="12" Glyph="" />
                </Button>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <!--  Completed section header  -->
        <TextBlock
          Margin="0,16,0,8"
          Style="{ThemeResource SubtitleTextBlockStyle}"
          Text="Completed"
          Visibility="{x:Bind ViewModel.HasCompletedUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
        />
        <!--  Completed list  -->
        <ListView
          IsItemClickEnabled="True"
          ItemClick="UpdateItem_ItemClick"
          ItemsSource="{x:Bind ViewModel.CompletedUpdates, Mode=OneWay}"
          SelectionMode="None"
          Visibility="{x:Bind ViewModel.HasCompletedUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
        >
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,4" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:UpdateItem">
              <Grid
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                ColumnSpacing="12"
                CornerRadius="8"
              >
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="60" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="8">
                  <Image Source="{Binding LogoUrl, Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
                <Grid Grid.Column="1" VerticalAlignment="Center" RowSpacing="2">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock
                    Grid.Row="0"
                    FontWeight="SemiBold"
                    Text="{x:Bind Title, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                  />
                  <TextBlock
                    Grid.Row="1"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{Binding StatusText, Mode=OneWay}"
                  />
                </Grid>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
