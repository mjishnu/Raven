<!--  Shared/CardViewControl.xaml  -->
<UserControl
  x:Class="test.Views.Shared.CardViewControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="using:test.Helpers"
  xmlns:layout="using:test.layouts"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:model="using:StoreListings.Library"
>
  <UserControl.Resources>
    <ResourceDictionary>
      <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
      <converters:OneDecimalPlaceConverter x:Key="OneDecimalPlaceConverter" />
      <converters:HideElementConverter x:Key="HideElementConverter" />
      <!--  Layout definition for ItemsRepeater  -->
      <layout:VirtualGridLayout
        x:Key="VirtualGridLayout"
        ItemsJustification="SpaceEvenly"
        ItemsStretch="Fill"
        MinColumnSpacing="17"
        MinItemHeight="224"
        MinItemWidth="191"
        MinRowSpacing="32"
      />
      <SolidColorBrush
        x:Key="SimpleCardBackgroundBrush"
        Color="{ThemeResource CardBackgroundFillColorDefault}"
      />
      <!--  DataTemplate section  (x:bind card itself via tag)  -->
      <DataTemplate x:Key="NormalItemTemplate" x:DataType="model:Card">
        <ItemContainer
          PointerEntered="Element_PointerEntered"
          PointerExited="Element_PointerExited"
          Tag="{x:Bind}"
          Tapped="Card_Tapped"
        >
          <Grid
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
          >
            <Grid.RowDefinitions>
              <RowDefinition Height="4*" />
              <RowDefinition Height="3*" />
            </Grid.RowDefinitions>
            <!--  Top section with image and background  -->
            <Border Background="{x:Bind Image.BackgroundColor}" CornerRadius="8,8,0,0">
              <Grid>
                <Image Source="{x:Bind Image.Url}" Stretch="Fill" />
                <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
                <Border
                  Width="80"
                  Height="80"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="{x:Bind Image.BackgroundColor}"
                  CornerRadius="10"
                >
                  <Image Source="{x:Bind Image.Url}" Stretch="Fill" />
                </Border>
              </Grid>
            </Border>
            <!--  Bottom section with text and rating  -->
            <StackPanel Grid.Row="1" Padding="10">
              <TextBlock
                Height="50"
                MaxLines="2"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{x:Bind Title}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="Wrap"
              />
              <Grid Height="50">
                <!--  Rating section  -->
                <StackPanel
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Orientation="Horizontal"
                  Visibility="{x:Bind AverageRating, Converter={StaticResource HideElementConverter}}"
                >
                  <TextBlock
                    FontSize="13"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind AverageRating, Converter={StaticResource OneDecimalPlaceConverter}}"
                  />
                  <TextBlock Margin="4,0,0,0" FontSize="13" Foreground="#FFB900" Text="★" />
                </StackPanel>
                <!--  Price section  -->
                <Border
                  Padding="6,4"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  CornerRadius="5"
                  Visibility="{x:Bind DisplayPrice, Converter={StaticResource HideElementConverter}}"
                >
                  <TextBlock
                    FontSize="13"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind DisplayPrice}"
                  />
                </Border>
              </Grid>
            </StackPanel>
          </Grid>
        </ItemContainer>
      </DataTemplate>
    </ResourceDictionary>
  </UserControl.Resources>
  <ScrollViewer x:Name="scrollViewer">
    <Grid>
      <!--  Loading State  -->
      <StackPanel
        x:Name="LoadingOverlay"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Opacity="0.9"
        Visibility="Collapsed"
      >
        <ProgressRing Width="50" Height="50" Background="LightGray" IsActive="True" />
        <StackPanel
          Margin="23,12,0,0"
          HorizontalAlignment="Center"
          Orientation="Horizontal"
          Spacing="0"
        >
          <TextBlock Text="Loading" />
          <TextBlock x:Name="LoadingDotsText" Width="24" HorizontalTextAlignment="Left" Text="." />
        </StackPanel>
      </StackPanel>
      <!--  Error State  -->
      <StackPanel
        x:Name="ErrorIcon"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Visibility="Collapsed"
      >
        <FontIcon FontSize="55" Glyph="" />
        <TextBlock x:Name="ErrorTextBlock" Margin="0,12,0,0" />
      </StackPanel>
      <!--  Content State  -->
      <StackPanel x:Name="DisplayItem" Margin="{StaticResource NavigationViewPageContentMargin}">
        <!--  Header Section  -->
        <StackPanel Grid.Row="0" Margin="0,24">
          <Grid Margin="0,0,0,27" HorizontalAlignment="Stretch">
            <TextBlock
              x:Name="HeaderTitle"
              HorizontalAlignment="Left"
              FontSize="24"
              Style="{ThemeResource SubtitleTextBlockStyle}"
              Text="{x:Bind HeaderText, Mode=OneWay}"
            />
            <Button
              x:Name="FilterBtn"
              HorizontalAlignment="Right"
              Background="Transparent"
              BorderThickness="0"
              Click="FilterBtn_Click"
              PointerEntered="FilterButton_PointerEntered"
              PointerExited="FilterButton_PointerExited"
            >
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                  <FontIcon FontSize="14" Glyph="" />
                  <TextBlock Margin="7,0,0,0" FontSize="14" Text="Filters" />
                </StackPanel>
                <FontIcon
                  x:Name="FilterBtnArrow"
                  Grid.Column="1"
                  Margin="20,0,0,0"
                  HorizontalAlignment="Right"
                  FontSize="14"
                  Glyph=""
                />
              </Grid>
            </Button>
          </Grid>
          <!--  Filter Panel  -->
          <StackPanel
            x:Name="FilterPanel"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="8"
            Visibility="Collapsed"
          >
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <ComboBox
                x:Name="FilterBox1"
                Grid.Column="0"
                Margin="39,27,13,0"
                HorizontalAlignment="Stretch"
                ItemsSource="{x:Bind ItemSourceFilter1}"
                SelectedIndex="{x:Bind SelectedFilterIndex1, Mode=TwoWay}"
              />
              <ComboBox
                x:Name="FilterBox2"
                Grid.Column="1"
                Margin="0,27,39,0"
                HorizontalAlignment="Stretch"
                ItemsSource="{x:Bind ItemSourceFilter2}"
                SelectedIndex="{x:Bind SelectedFilterIndex2, Mode=TwoWay}"
              />
            </Grid>
            <Grid Margin="39,25,39,25">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button
                x:Name="ApplyBtn"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Click="ApplyBtn_Click"
              >
                                Apply
                            </Button
              >
            </Grid>
          </StackPanel>
        </StackPanel>
        <ItemsView
          Grid.Row="1"
          Padding="10"
          ItemTemplate="{StaticResource NormalItemTemplate}"
          ItemsSource="{x:Bind ItemsSource}"
          Layout="{StaticResource VirtualGridLayout}"
        />
        <!--  No Results  -->
        <StackPanel
          x:Name="NoResultsPanel"
          Margin="0,120"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Visibility="Collapsed"
        >
          <FontIcon FontSize="42" Glyph="" />
          <TextBlock
            Margin="0,8,0,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="24"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="No results found"
          />
          <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="16"
            Text="Try different keywords or remove search filters"
          />
        </StackPanel>
        <!--  Loading More Indicator  -->
        <ProgressRing
          x:Name="LoadMoreIndicator"
          Width="30"
          Height="30"
          Margin="20"
          Background="LightGray"
          IsActive="True"
          Visibility="Collapsed"
        />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
