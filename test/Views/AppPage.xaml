<Page
  x:Class="test.Views.AppPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
>
  <Page.Resources>
    <Style x:Key="TransparentButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </Page.Resources>
  <Grid>
  <ScrollViewer>
    <Grid>
      <StackPanel
        x:Name="LoadingOverlay"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Opacity="0.9"
      >
        <ProgressRing Width="50" Height="50" Background="LightGray" IsActive="True" />
        <TextBlock
          Margin="0,12,0,0"
          Style="{StaticResource BodyTextBlockStyle}"
          Text="Loading..."
        />
      </StackPanel>
      <StackPanel
        x:Name="DisplayItem"
        Margin="{StaticResource NavigationViewPageContentMargin}"
        Padding="16"
      >
        <StackPanel Margin="0" Orientation="Vertical">
          <!--  App Details Section  -->
          <Grid>
            <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
              <!--  App Icon  -->
              <Border Width="80" Height="80" Margin="0,0,12,0" CornerRadius="10">
                <Image Source="{x:Bind AppData.Logo.Url, Mode=OneWay}" Stretch="Fill" />
              </Border>
              <StackPanel>
                <!--  App Name and Publisher  -->
                <TextBlock
                  FontSize="26"
                  Style="{ThemeResource TitleTextBlockStyle}"
                  Text="{x:Bind AppData.Title, Mode=OneWay}"
                />
                <TextBlock
                  FontSize="14"
                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                  Text="{x:Bind AppData.PublisherName, Mode=OneWay}"
                />
                <!--  Rating and Category  -->
                <StackPanel
                  Margin="0,12,0,0"
                  Orientation="Horizontal"
                  Visibility="{x:Bind AppData.RatingCount, Converter={StaticResource HideElementConverter}, Mode=OneWay}"
                >
                  <TextBlock
                    Margin="4,0"
                    FontSize="14"
                    Text="{x:Bind AppData.Rating, Mode=OneWay, Converter={StaticResource OneDecimalPlaceConverter}}"
                  />
                  <FontIcon
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph=""
                  />
                  <TextBlock
                    Margin="8,0"
                    FontSize="14"
                    Foreground="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Text="|"
                  />
                  <TextBlock FontSize="14" Text="{x:Bind AppData.RatingCount, Mode=OneWay}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
            <!--  More Options Button  -->
            <Button
              x:Name="MoreOptionsButton"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Background="Transparent"
              BorderBrush="Transparent"
              BorderThickness="0"
            >
              <FontIcon FontSize="16" Glyph="" />
              <Button.Flyout>
                <MenuFlyout
                  FlyoutBase.ShouldConstrainToRootBounds="True"
                  Opening="MoreOptionsFlyout_Opening"
                  Placement="Bottom"
                >
                  <MenuFlyout.MenuFlyoutPresenterStyle>
                    <Style TargetType="MenuFlyoutPresenter">
                      <Setter Property="Padding" Value="0,4" />
                    </Style>
                  </MenuFlyout.MenuFlyoutPresenterStyle>
                  <!--  Checkbox-style toggle: custom template for consistent height/margin  -->
                  <ToggleMenuFlyoutItem x:Name="IgnoreDependencyFilterToggle" Text="Bypass Filters">
                    <ToggleMenuFlyoutItem.Style>
                      <Style TargetType="ToggleMenuFlyoutItem">
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="ToggleMenuFlyoutItem">
                              <Grid
                                x:Name="LayoutRoot"
                                MinHeight="32"
                                Padding="12,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                              >
                                <CheckBox
                                  x:Name="CheckBoxControl"
                                  Margin="0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding Text}"
                                  FontSize="{TemplateBinding FontSize}"
                                  Foreground="{TemplateBinding Foreground}"
                                  IsChecked="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  IsHitTestVisible="False"
                                />
                                <VisualStateManager.VisualStateGroups>
                                  <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                      <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Background" Value="{ThemeResource MenuFlyoutItemBackgroundPointerOver}" />
                                      </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                      <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Background" Value="{ThemeResource MenuFlyoutItemBackgroundPressed}" />
                                      </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                  </VisualStateGroup>
                                  <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Checked" />
                                    <VisualState x:Name="UncheckedWithIcon" />
                                    <VisualState x:Name="CheckedWithIcon" />
                                  </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                              </Grid>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </ToggleMenuFlyoutItem.Style>
                  </ToggleMenuFlyoutItem>
                  <MenuFlyoutSeparator />
                  <!--  Button-style item: custom template removes icon column, centers text  -->
                  <MenuFlyoutItem
                    x:Name="CheckUpdate"
                    Click="CheckUpdate_Click"
                    Text="Check Updates"
                  >
                    <MenuFlyoutItem.Style>
                      <Style TargetType="MenuFlyoutItem">
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="MenuFlyoutItem">
                              <Grid
                                x:Name="LayoutRoot"
                                MinHeight="32"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                              >
                                <TextBlock
                                  x:Name="TextBlock"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontSize="{TemplateBinding FontSize}"
                                  Foreground="{TemplateBinding Foreground}"
                                  Text="{TemplateBinding Text}"
                                />
                                <VisualStateManager.VisualStateGroups>
                                  <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                      <Storyboard>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="LayoutRoot"
                                          Storyboard.TargetProperty="Background"
                                        >
                                          <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                        </ObjectAnimationUsingKeyFrames>
                                      </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                      <Storyboard>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="LayoutRoot"
                                          Storyboard.TargetProperty="Background"
                                        >
                                          <DiscreteObjectKeyFrame
                                            KeyTime="0"
                                            Value="{ThemeResource MenuFlyoutItemBackgroundPointerOver}"
                                          />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="TextBlock"
                                          Storyboard.TargetProperty="Foreground"
                                        >
                                          <DiscreteObjectKeyFrame
                                            KeyTime="0"
                                            Value="{ThemeResource MenuFlyoutItemForegroundPointerOver}"
                                          />
                                        </ObjectAnimationUsingKeyFrames>
                                      </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                      <Storyboard>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="LayoutRoot"
                                          Storyboard.TargetProperty="Background"
                                        >
                                          <DiscreteObjectKeyFrame
                                            KeyTime="0"
                                            Value="{ThemeResource MenuFlyoutItemBackgroundPressed}"
                                          />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="TextBlock"
                                          Storyboard.TargetProperty="Foreground"
                                        >
                                          <DiscreteObjectKeyFrame
                                            KeyTime="0"
                                            Value="{ThemeResource MenuFlyoutItemForegroundPressed}"
                                          />
                                        </ObjectAnimationUsingKeyFrames>
                                      </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                      <Storyboard>
                                        <ObjectAnimationUsingKeyFrames
                                          Storyboard.TargetName="TextBlock"
                                          Storyboard.TargetProperty="Foreground"
                                        >
                                          <DiscreteObjectKeyFrame
                                            KeyTime="0"
                                            Value="{ThemeResource MenuFlyoutItemForegroundDisabled}"
                                          />
                                        </ObjectAnimationUsingKeyFrames>
                                      </Storyboard>
                                    </VisualState>
                                  </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                              </Grid>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </MenuFlyoutItem.Style>
                  </MenuFlyoutItem>
                </MenuFlyout>
              </Button.Flyout>
            </Button>
          </Grid>
          <!--  Short Description  -->
          <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="3*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <TextBlock
              Grid.Column="0"
              Margin="0,24"
              HorizontalAlignment="Left"
              FontSize="14"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              MaxLines="2"
              Text="{x:Bind AppData.Description, Mode=OneWay}"
              TextTrimming="CharacterEllipsis"
              TextWrapping="Wrap"
            />
          </Grid>
        </StackPanel>
        <!--  install/open/update button  -->
        <SplitButton
          x:Name="InstallButton"
          Height="40"
          MinWidth="120"
          Background="{ThemeResource AccentFillColorDefaultBrush}"
          Click="InstallButton_Click"
          Content="Install"
          FontSize="16"
          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
        >
          <SplitButton.Flyout>
            <MenuFlyout
              x:Name="InstallButtonFlyout"
              FlyoutBase.ShouldConstrainToRootBounds="True"
            />
          </SplitButton.Flyout>
        </SplitButton>
        <!--  Progress button Section  -->
        <Grid
          x:Name="ProgressSection"
          Margin="6,0,0,0"
          VerticalAlignment="Center"
          ColumnSpacing="8"
          Visibility="Collapsed"
        >
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Spacing="4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock
                x:Name="StatusText"
                Grid.Column="0"
                HorizontalAlignment="Left"
                Style="{ThemeResource CaptionTextBlockStyle}"
              />
              <TextBlock
                x:Name="DetailsText"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
              />
            </Grid>
            <ProgressBar
              x:Name="ProgressBar"
              VerticalAlignment="Center"
              IsIndeterminate="False"
              Maximum="100"
              Minimum="0"
              ShowError="False"
              ShowPaused="False"
              Visibility="Visible"
              Value="{x:Bind UpdateService.Progress, Mode=OneWay}"
            />
          </StackPanel>
          <Button
            x:Name="StopButton"
            Grid.Column="1"
            VerticalAlignment="Center"
            Click="StopButton_Click"
            Style="{StaticResource TransparentButtonStyle}"
          >
            <FontIcon Glyph="" />
          </Button>
        </Grid>
        <!--  Screenshots Section  -->
        <StackPanel
          Margin="0,36,0,0"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="10"
        >
          <TextBlock
            Margin="24,12"
            FontSize="18"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Text="Screenshots"
          />
          <!--  Divider  -->
          <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
          <Grid>
            <!--  Left Arrow Button - Fixed with correct Glyph and ZIndex  -->
            <Button
              x:Name="LeftArrowButton"
              Width="40"
              Height="40"
              Margin="8,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Canvas.ZIndex="10"
              Click="LeftArrowButton_Click"
              CornerRadius="26"
            >
              <FontIcon
                Margin="0,0,1,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="15"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph=""
              />
            </Button>
            <!--  ScrollViewer for ItemsRepeater - Added PointerWheelChanged handler to prevent wheel scrolling  -->
            <ScrollViewer
              x:Name="ScreenshotsScrollViewer"
              Padding="24"
              HorizontalScrollBarVisibility="Hidden"
              HorizontalScrollMode="Disabled"
              VerticalScrollBarVisibility="Disabled"
              VerticalScrollMode="Disabled"
            >
              <ItemsRepeater
                x:Name="ScreenshotRepeater"
                ItemsSource="{x:Bind AppData.Screenshots, Mode=OneWay}"
                ElementPrepared="ScreenshotRepeater_ElementPrepared"
              >
                <ItemsRepeater.Layout>
                  <StackLayout Orientation="Horizontal" Spacing="24" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <Button
                      Background="Transparent"
                      BorderBrush="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      CornerRadius="10"
                    >
                      <Border CornerRadius="10">
                        <Image Width="630" Height="350" Source="{Binding Url}" Stretch="Fill" />
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </ScrollViewer>
            <!--  Right Arrow Button - Fixed with correct Glyph  -->
            <Button
              x:Name="RightArrowButton"
              Width="40"
              Height="40"
              Margin="0,0,8,0"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Canvas.ZIndex="10"
              Click="RightArrowButton_Click"
              CornerRadius="26"
            >
              <FontIcon
                Margin="1,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="15"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph=""
              />
            </Button>
          </Grid>
        </StackPanel>
        <!--  Full Description Section  -->
        <StackPanel
          Margin="0,8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="10"
        >
          <TextBlock
            Margin="24,12"
            FontSize="18"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Text="Description"
          />
          <!--  Divider  -->
          <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
          <TextBlock
            Margin="24,24"
            FontSize="14"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{x:Bind AppData.Description, Mode=OneWay}"
            TextWrapping="Wrap"
          />
        </StackPanel>
        <!--  More Details Section  -->
        <StackPanel
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="10"
        >
          <TextBlock
            Margin="24,12"
            FontSize="18"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            Text="More Details"
          />
          <!--  Divider  -->
          <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
          <Grid Margin="24,24">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  App Size  -->
            <TextBlock
              Grid.Row="0"
              Grid.Column="0"
              Margin="0,5"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Text="App Size:"
            />
            <TextBlock
              Grid.Row="0"
              Grid.Column="1"
              Margin="0,5"
              Text="{x:Bind AppData.Size, Mode=OneWay}"
            />
            <!--  Version  -->
            <TextBlock
              Grid.Row="1"
              Grid.Column="0"
              Margin="0,5"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Text="Version:"
            />
            <TextBlock
              Grid.Row="1"
              Grid.Column="1"
              Margin="0,5"
              Text="{x:Bind AppData.Version, Mode=OneWay}"
            />
            <!--  Last Updated  -->
            <TextBlock
              Grid.Row="2"
              Grid.Column="0"
              Margin="0,5"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Text="Last Updated:"
            />
            <TextBlock
              Grid.Row="2"
              Grid.Column="1"
              Margin="0,5"
              Text="{x:Bind AppData.LastUpdated, Mode=OneWay}"
            />
          </Grid>
        </StackPanel>
      </StackPanel>
    </Grid>
  </ScrollViewer>
  <!--  Lightbox overlay  -->
  <Grid x:Name="LightboxOverlay" Visibility="Collapsed">
    <Rectangle Tapped="LightboxBackdrop_Tapped">
      <Rectangle.Fill>
        <AcrylicBrush TintColor="#000000" TintOpacity="0.7" TintLuminosityOpacity="0.0" FallbackColor="#CC000000" />
      </Rectangle.Fill>
    </Rectangle>
    <Button
      x:Name="LightboxCloseButton"
      HorizontalAlignment="Right"
      VerticalAlignment="Top"
      Margin="16"
      Background="Transparent"
      BorderBrush="Transparent"
      BorderThickness="0"
      Click="LightboxClose_Click"
    >
      <FontIcon FontSize="18" Foreground="White" Glyph="&#xE711;" />
    </Button>
    <Grid Margin="80,52,80,48">
      <Border HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="10">
        <Image
          x:Name="LightboxImage"
          MaxWidth="1100"
          MaxHeight="620"
          Stretch="Uniform"
        />
      </Border>
    </Grid>
    <Border
      Width="48"
      Height="48"
      HorizontalAlignment="Left"
      VerticalAlignment="Center"
      Margin="16,0"
      Background="Transparent"
      CornerRadius="24"
      Tapped="LightboxNavArea_Tapped"
    >
      <Button
        x:Name="LightboxLeftButton"
        Width="48"
        Height="48"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        Click="LightboxLeft_Click"
        CornerRadius="24"
      >
        <FontIcon FontSize="16" Glyph="&#xE76B;" />
      </Button>
    </Border>
    <Border
      Width="48"
      Height="48"
      HorizontalAlignment="Right"
      VerticalAlignment="Center"
      Margin="0,0,16,0"
      Background="Transparent"
      CornerRadius="24"
      Tapped="LightboxNavArea_Tapped"
    >
      <Button
        x:Name="LightboxRightButton"
        Width="48"
        Height="48"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        Click="LightboxRight_Click"
        CornerRadius="24"
      >
        <FontIcon FontSize="16" Glyph="&#xE76C;" />
      </Button>
    </Border>
    <TextBlock
      x:Name="LightboxCounter"
      HorizontalAlignment="Center"
      VerticalAlignment="Bottom"
      Margin="0,0,0,16"
      FontSize="14"
      Foreground="White"
    />
  </Grid>
  </Grid>
</Page>
